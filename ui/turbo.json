{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "rm-build-dir": {
      "cache": false,
      "dependsOn": ["^rm-build-dir"]
    },
    "test": {
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "lint-check": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format-check": {
      "cache": false
    },
    "build": {
      "dependsOn": ["rm-build-dir", "^build"],
      "outputs": ["dist/**"]
    },
    "move-build": {
      "dependsOn": ["^move-build"],
      "persistent": true,
      "cache": false
    },
    "build-storybook": {
      "dependsOn": ["build"]
    }
  }
}
