{
  "include": ["./**/*.ts"],
  "exclude": [
    "./tests-out",
    // Excluded until DBClusterDetailsTabs enum values (components, backups, restores, logs)
    // are re-enabled. Remove these excludes when those tabs are connected to the new instance API.
    "./pr/db-cluster-details/components/**",
    "./pr/db-cluster-details/schedules.e2e.ts",
    "./pr/multinamespaces/**"
  ],
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["node", "@testing-library/jest-dom", "vitest/globals"],
    "paths": {
      "@e2e/*": ["./*"],
      "@percona/ui-lib": ["../../../packages/ui-lib/src"],
      "@percona/design": ["../../../packages/design/src"],
      "@percona/types": ["../../../packages/types/src"],
      "@percona/utils": ["../../../packages/utils/src"],
      "@generated/api-types": ["../../../api/index.ts"]
    },
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "target": "ES2020",
    "module": "ESNext",
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "sourceMap": true,
    "outDir": "./tests-out"
  }
}
